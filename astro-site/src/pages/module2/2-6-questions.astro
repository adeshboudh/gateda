---
import VizLayout from '../../layouts/VizLayout.astro';
const title = "2.6 Algorithm Complexity · GATE DA";
---
<VizLayout {title} currentPath="/module2/2-6-questions" pageCss="/assets/css/pages/1-1-questions.css">

<div class="gd-breadcrumb">
  <a href="/index.html">Home</a><span>›</span>
  <a href="/module2.html">Module 2</a><span>›</span>
  2.6 Questions
</div>
<a class="gd-pill-link" href="/module2/viz-2-6-complexity.html">← Theory &amp; Visualizations</a>

<div class="gd-viz-header">
  <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;">
    <span class="gd-badge gd-badge--subject">Module 2 · DSA</span>
    <span class="gd-badge gd-badge--pyq">10 questions · MCQ / NAT / MSQ</span>
  </div>
  <h1 id="top">2.6 Algorithm Complexity Practice Questions</h1>
  <p>GATE-style questions. Attempt before revealing answer. NAT/MSQ: no negative marking; MCQ: −⅓ mark.</p>
</div>

<div class="q-score-bar">
  <div>
    <div class="q-score-bar__count"><span id="score-num">0</span> / 10</div>
    <div class="q-score-bar__label">correct answers revealed</div>
  </div>
  <button class="q-score-bar__reset" onclick="resetAll()">Reset all</button>
</div>

<div class="q-list">

  <div class="q-card" id="qc1">
    <div class="q-header"><span class="q-num">Q1</span><span class="q-type">MCQ</span><span class="q-diff">★</span><span class="q-marks">1 mark</span></div>
    <div class="q-body">For large $n$, which grows faster?</div>
    <div class="q-options" id="q1-opts">
      <div class="q-opt" data-q="1" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $O(n \log n)$</div>
      <div class="q-opt" data-q="1" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $O(n^2)$</div>
      <div class="q-opt" data-q="1" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> they are equal</div>
      <div class="q-opt" data-q="1" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $O(n \log n)$ for even $n$ only</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(1,'mcq','B')">Check</button>
      <div class="q-answer" id="q1-ans"><b><span class="ans-correct">✓ (B) $O(n^2)$.</span></b> $n^2$ eventually exceeds $n \log n$ since $n &gt; \log n$ for large $n$.</div>
    </div>
  </div>

  <div class="q-card" id="qc2">
    <div class="q-header"><span class="q-num">Q2</span><span class="q-type">MCQ</span><span class="q-diff">★★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">By the Master theorem, $T(n) = 2T(n/2) + n$ solves to</div>
    <div class="q-options" id="q2-opts">
      <div class="q-opt" data-q="2" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $\Theta(n)$</div>
      <div class="q-opt" data-q="2" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $\Theta(n \log n)$</div>
      <div class="q-opt" data-q="2" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> $\Theta(n^2)$</div>
      <div class="q-opt" data-q="2" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $\Theta(\log n)$</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(2,'mcq','B')">Check</button>
      <div class="q-answer" id="q2-ans"><b><span class="ans-correct">✓ (B) $\Theta(n \log n)$.</span></b> $\log_2 2 = 1$ and $f(n) = n = \Theta(n^1)$ → case 2 (merge sort).</div>
    </div>
  </div>

  <div class="q-card" id="qc3">
    <div class="q-header"><span class="q-num">Q3</span><span class="q-type q-type--nat">NAT</span><span class="q-diff">★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">$T(n) = 2T(n-1) + 1$ with $T(1) = 1$. Find $T(5)$.</div>
    <div class="q-nat"><input class="q-nat__input" id="q3-input" type="number" step="any" placeholder="your answer"><span class="q-nat__label">value</span></div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(3,30.9,31.1)">Check</button>
      <div class="q-answer" id="q3-ans"><b><span class="ans-correct">✓ 31.</span></b> Closed form $T(n) = 2^n - 1$, so $T(5) = 2^5 - 1 = 31$ (Towers of Hanoi).</div>
    </div>
  </div>

  <div class="q-card" id="qc4">
    <div class="q-header"><span class="q-num">Q4</span><span class="q-type">MCQ</span><span class="q-diff">★★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">$T(n) = 4T(n/2) + n$ solves to</div>
    <div class="q-options" id="q4-opts">
      <div class="q-opt" data-q="4" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $\Theta(n)$</div>
      <div class="q-opt" data-q="4" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $\Theta(n \log n)$</div>
      <div class="q-opt" data-q="4" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> $\Theta(n^2)$</div>
      <div class="q-opt" data-q="4" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $\Theta(n^2 \log n)$</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(4,'mcq','C')">Check</button>
      <div class="q-answer" id="q4-ans"><b><span class="ans-correct">✓ (C) $\Theta(n^2)$.</span></b> $\log_2 4 = 2$, $f(n) = n \lt n^2$ → case 1 → $\Theta(n^2)$.</div>
    </div>
  </div>

  <div class="q-card" id="qc5">
    <div class="q-header"><span class="q-num">Q5</span><span class="q-type q-type--msq">MSQ</span><span class="q-diff">★★</span><span class="q-marks">2 marks · no negative</span></div>
    <div class="q-body">Which algorithms have $O(n \log n)$ worst-case time? (Select all.)</div>
    <div class="q-options" id="q5-opts">
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="5" data-val="A"> <span class="q-opt-key">A</span> Merge sort</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="5" data-val="B"> <span class="q-opt-key">B</span> Heap sort</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="5" data-val="C"> <span class="q-opt-key">C</span> Quick sort</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="5" data-val="D"> <span class="q-opt-key">D</span> Binary search</label>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkMsq(5,['A','B'])">Check</button>
      <div class="q-answer" id="q5-ans"><b><span class="ans-correct">✓ (A), (B).</span></b> Merge and heap sort are $O(n \log n)$ worst case. Quick sort is $O(n^2)$ worst; binary search is $O(\log n)$.</div>
    </div>
  </div>

  <div class="q-card" id="qc6">
    <div class="q-header"><span class="q-num">Q6</span><span class="q-type">MCQ</span><span class="q-diff">★</span><span class="q-marks">1 mark</span></div>
    <div class="q-body">The best-case time of binary search is</div>
    <div class="q-options" id="q6-opts">
      <div class="q-opt" data-q="6" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $O(1)$</div>
      <div class="q-opt" data-q="6" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $O(\log n)$</div>
      <div class="q-opt" data-q="6" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> $O(n)$</div>
      <div class="q-opt" data-q="6" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $O(\log \log n)$</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(6,'mcq','A')">Check</button>
      <div class="q-answer" id="q6-ans"><b><span class="ans-correct">✓ (A) $O(1)$.</span></b> If the target is the first mid, one comparison suffices.</div>
    </div>
  </div>

  <div class="q-card" id="qc7">
    <div class="q-header"><span class="q-num">Q7</span><span class="q-type">MCQ</span><span class="q-diff">★</span><span class="q-marks">1 mark</span></div>
    <div class="q-body">The auxiliary space of recursive DFS on a graph with $V$ vertices is</div>
    <div class="q-options" id="q7-opts">
      <div class="q-opt" data-q="7" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $O(1)$</div>
      <div class="q-opt" data-q="7" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $O(V)$</div>
      <div class="q-opt" data-q="7" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> $O(V^2)$</div>
      <div class="q-opt" data-q="7" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $O(\log V)$</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(7,'mcq','B')">Check</button>
      <div class="q-answer" id="q7-ans"><b><span class="ans-correct">✓ (B) $O(V)$.</span></b> The recursion stack can hold up to $V$ vertices on a deep path.</div>
    </div>
  </div>

  <div class="q-card" id="qc8">
    <div class="q-header"><span class="q-num">Q8</span><span class="q-type">MCQ</span><span class="q-diff">★★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">$T(n) = T(n/2) + 1$ solves to</div>
    <div class="q-options" id="q8-opts">
      <div class="q-opt" data-q="8" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $\Theta(1)$</div>
      <div class="q-opt" data-q="8" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $\Theta(\log n)$</div>
      <div class="q-opt" data-q="8" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> $\Theta(n)$</div>
      <div class="q-opt" data-q="8" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $\Theta(n \log n)$</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(8,'mcq','B')">Check</button>
      <div class="q-answer" id="q8-ans"><b><span class="ans-correct">✓ (B) $\Theta(\log n)$.</span></b> $\log_2 1 = 0$, $f(n) = 1 = \Theta(n^0)$ → case 2 → $\Theta(\log n)$ (binary search).</div>
    </div>
  </div>

  <div class="q-card" id="qc9">
    <div class="q-header"><span class="q-num">Q9</span><span class="q-type">MCQ</span><span class="q-diff">★</span><span class="q-marks">1 mark</span></div>
    <div class="q-body">Which sorting algorithm uses $O(1)$ auxiliary space and is $O(n \log n)$ worst case?</div>
    <div class="q-options" id="q9-opts">
      <div class="q-opt" data-q="9" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> Merge sort</div>
      <div class="q-opt" data-q="9" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> Heap sort</div>
      <div class="q-opt" data-q="9" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> Counting sort</div>
      <div class="q-opt" data-q="9" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> Radix sort</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(9,'mcq','B')">Check</button>
      <div class="q-answer" id="q9-ans"><b><span class="ans-correct">✓ (B) Heap sort.</span></b> Heap sort sorts in place with $O(n \log n)$ worst-case time.</div>
    </div>
  </div>

  <div class="q-card" id="qc10">
    <div class="q-header"><span class="q-num">Q10</span><span class="q-type q-type--nat">NAT</span><span class="q-diff">★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">Towers of Hanoi with $n = 6$ disks requires how many moves?</div>
    <div class="q-nat"><input class="q-nat__input" id="q10-input" type="number" step="any" placeholder="your answer"><span class="q-nat__label">moves</span></div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(10,62.9,63.1)">Check</button>
      <div class="q-answer" id="q10-ans"><b><span class="ans-correct">✓ 63.</span></b> $2^n - 1 = 2^6 - 1 = 63$ moves.</div>
    </div>
  </div>

</div><!-- end q-list -->

<div style="margin-top:32px;padding-top:24px;border-top:1px solid var(--gd-border);display:flex;gap:12px;flex-wrap:wrap;">
  <a class="gd-pill-link" href="/module2/2-6-bank.html" style="margin-top:0;">Question Bank (20 Qs) →</a>
  <a class="gd-pill-link" href="/module2.html" style="margin-top:0;">← Module 2 Overview</a>
</div>

<script is:inline slot="scripts">
var scores={};
function updateScore(){document.getElementById('score-num').textContent=Object.values(scores).filter(Boolean).length;}
function selectOpt(el){var q=el.dataset.q;var card=document.getElementById('qc'+q);if(card.classList.contains('q-card--correct')||card.classList.contains('q-card--wrong'))return;document.querySelectorAll('[data-q="'+q+'"].q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected');});el.classList.add('q-opt--selected');}
function check(q,type,correct){var card=document.getElementById('qc'+q);var selected=document.querySelector('[data-q="'+q+'"].q-opt--selected');var ansEl=document.getElementById('q'+q+'-ans');var btn=card.querySelector('.q-check-btn');if(!selected)return;var val=selected.dataset.val;var isCorrect=val===correct;document.querySelectorAll('[data-q="'+q+'"].q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected');if(o.dataset.val===correct)o.classList.add('q-opt--correct');else if(o.dataset.val===val&&!isCorrect)o.classList.add('q-opt--wrong');o.style.pointerEvents='none';});card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');ansEl.style.display='block';btn.disabled=true;scores[q]=isCorrect;updateScore();}
function checkNat(q,min,max){var input=document.getElementById('q'+q+'-input');var ansEl=document.getElementById('q'+q+'-ans');var card=document.getElementById('qc'+q);var btn=card.querySelector('.q-check-btn');var val=parseFloat(input.value);var isCorrect=!isNaN(val)&&val>=min&&val<=max;input.classList.add(isCorrect?'q-nat__input--correct':'q-nat__input--wrong');input.disabled=true;ansEl.style.display='block';btn.disabled=true;card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');scores[q]=isCorrect;updateScore();}
function checkMsq(q,correctArr){var card=document.getElementById('qc'+q);var ansEl=document.getElementById('q'+q+'-ans');var btn=card.querySelector('.q-check-btn');var checked=Array.from(document.querySelectorAll('[data-q="'+q+'"]:checked')).map(function(c){return c.dataset.val;});var isCorrect=correctArr.length===checked.length&&correctArr.every(function(v){return checked.includes(v);});card.querySelectorAll('.q-opt--msq').forEach(function(label){var val=label.querySelector('input').dataset.val;if(correctArr.includes(val))label.classList.add('q-opt--correct');else if(checked.includes(val))label.classList.add('q-opt--wrong');label.querySelector('input').disabled=true;label.style.pointerEvents='none';});card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');ansEl.style.display='block';btn.disabled=true;scores[q]=isCorrect;updateScore();}
function resetAll(){scores={};updateScore();document.querySelectorAll('.q-card').forEach(function(c){c.classList.remove('q-card--correct','q-card--wrong');});document.querySelectorAll('.q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected','q-opt--correct','q-opt--wrong');o.style.pointerEvents='';});document.querySelectorAll('.q-nat__input').forEach(function(i){i.value='';i.disabled=false;i.classList.remove('q-nat__input--correct','q-nat__input--wrong');});document.querySelectorAll('.q-opt--msq input').forEach(function(c){c.checked=false;c.disabled=false;});document.querySelectorAll('.q-opt--msq').forEach(function(l){l.classList.remove('q-opt--correct','q-opt--wrong');l.style.pointerEvents='';});document.querySelectorAll('.q-answer').forEach(function(a){a.style.display='none';});document.querySelectorAll('.q-check-btn').forEach(function(b){b.disabled=false;});}
</script>
</VizLayout>
