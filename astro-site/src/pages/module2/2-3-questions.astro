---
import VizLayout from '../../layouts/VizLayout.astro';
const title = "2.3 Recursion & DP · GATE DA";
---
<VizLayout {title} currentPath="/module2/2-3-questions" pageCss="/assets/css/pages/1-1-questions.css">

<div class="gd-breadcrumb">
  <a href="/index.html">Home</a><span>›</span>
  <a href="/module2.html">Module 2</a><span>›</span>
  2.3 Questions
</div>
<a class="gd-pill-link" href="/module2/viz-2-3-dp.html">← Theory &amp; Visualizations</a>

<div class="gd-viz-header">
  <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;">
    <span class="gd-badge gd-badge--subject">Module 2 · DSA</span>
    <span class="gd-badge gd-badge--pyq">10 questions · MCQ / NAT / MSQ</span>
  </div>
  <h1 id="top">2.3 Recursion &amp; Dynamic Programming Practice Questions</h1>
  <p>GATE-style questions. Attempt before revealing answer. NAT/MSQ: no negative marking; MCQ: −⅓ mark.</p>
</div>

<div class="q-score-bar">
  <div>
    <div class="q-score-bar__count"><span id="score-num">0</span> / 10</div>
    <div class="q-score-bar__label">correct answers revealed</div>
  </div>
  <button class="q-score-bar__reset" onclick="resetAll()">Reset all</button>
</div>

<div class="q-list">

  <div class="q-card" id="qc1">
    <div class="q-header"><span class="q-num">Q1</span><span class="q-type">MCQ</span><span class="q-diff">★</span><span class="q-marks">1 mark</span></div>
    <div class="q-body">The time complexity of naive recursive Fibonacci (no memoization) is</div>
    <div class="q-options" id="q1-opts">
      <div class="q-opt" data-q="1" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $O(n)$</div>
      <div class="q-opt" data-q="1" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $O(n^2)$</div>
      <div class="q-opt" data-q="1" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> $O(2^n)$</div>
      <div class="q-opt" data-q="1" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $O(\log n)$</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(1,'mcq','C')">Check</button>
      <div class="q-answer" id="q1-ans"><b><span class="ans-correct">✓ (C) $O(2^n)$.</span></b> The recursion tree branches twice each level with massive recomputation; memoization collapses it to $O(n)$.</div>
    </div>
  </div>

  <div class="q-card" id="qc2">
    <div class="q-header"><span class="q-num">Q2</span><span class="q-type q-type--nat">NAT</span><span class="q-diff">★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">With $F(0)=0$, $F(1)=1$, compute $F(6)$.</div>
    <div class="q-nat"><input class="q-nat__input" id="q2-input" type="number" step="any" placeholder="your answer"><span class="q-nat__label">value</span></div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(2,7.9,8.1)">Check</button>
      <div class="q-answer" id="q2-ans"><b><span class="ans-correct">✓ 8.</span></b> Sequence: 0,1,1,2,3,5,8. $F(6)=8$.</div>
    </div>
  </div>

  <div class="q-card" id="qc3">
    <div class="q-header"><span class="q-num">Q3</span><span class="q-type q-type--nat">NAT</span><span class="q-diff">★★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">Length of the LCS of "AGGTAB" and "GXTXAYB".</div>
    <div class="q-nat"><input class="q-nat__input" id="q3-input" type="number" step="any" placeholder="your answer"><span class="q-nat__label">length</span></div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(3,3.9,4.1)">Check</button>
      <div class="q-answer" id="q3-ans"><b><span class="ans-correct">✓ 4.</span></b> The LCS is "GTAB" of length 4.</div>
    </div>
  </div>

  <div class="q-card" id="qc4">
    <div class="q-header"><span class="q-num">Q4</span><span class="q-type">MCQ</span><span class="q-diff">★</span><span class="q-marks">1 mark</span></div>
    <div class="q-body">Dynamic programming applies when a problem has</div>
    <div class="q-options" id="q4-opts">
      <div class="q-opt" data-q="4" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> only optimal substructure</div>
      <div class="q-opt" data-q="4" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> only overlapping subproblems</div>
      <div class="q-opt" data-q="4" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> overlapping subproblems and optimal substructure</div>
      <div class="q-opt" data-q="4" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> no recursive structure</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(4,'mcq','C')">Check</button>
      <div class="q-answer" id="q4-ans"><b><span class="ans-correct">✓ (C).</span></b> Both properties are required — overlap makes caching pay off, optimal substructure makes composition valid.</div>
    </div>
  </div>

  <div class="q-card" id="qc5">
    <div class="q-header"><span class="q-num">Q5</span><span class="q-type q-type--nat">NAT</span><span class="q-diff">★★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">0/1 knapsack: items (w,v) = (1,1),(3,4),(4,5),(5,7), capacity $W=7$. Maximum value?</div>
    <div class="q-nat"><input class="q-nat__input" id="q5-input" type="number" step="any" placeholder="your answer"><span class="q-nat__label">value</span></div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(5,8.9,9.1)">Check</button>
      <div class="q-answer" id="q5-ans"><b><span class="ans-correct">✓ 9.</span></b> Best is items (3,4)+(4,5) = weight 7, value 9. (5,7)+(1,1)=value 8 is worse.</div>
    </div>
  </div>

  <div class="q-card" id="qc6">
    <div class="q-header"><span class="q-num">Q6</span><span class="q-type">MCQ</span><span class="q-diff">★</span><span class="q-marks">1 mark</span></div>
    <div class="q-body">Top-down DP (memoization) typically stores results in</div>
    <div class="q-options" id="q6-opts">
      <div class="q-opt" data-q="6" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> a stack only</div>
      <div class="q-opt" data-q="6" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> a hash map or array indexed by subproblem</div>
      <div class="q-opt" data-q="6" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> a priority queue</div>
      <div class="q-opt" data-q="6" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> no storage at all</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(6,'mcq','B')">Check</button>
      <div class="q-answer" id="q6-ans"><b><span class="ans-correct">✓ (B).</span></b> Memoization caches each subproblem's answer in a table/map keyed by its parameters.</div>
    </div>
  </div>

  <div class="q-card" id="qc7">
    <div class="q-header"><span class="q-num">Q7</span><span class="q-type q-type--nat">NAT</span><span class="q-diff">★★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">Length of the Longest Increasing Subsequence of [10, 9, 2, 5, 3, 7, 101, 18].</div>
    <div class="q-nat"><input class="q-nat__input" id="q7-input" type="number" step="any" placeholder="your answer"><span class="q-nat__label">length</span></div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(7,3.9,4.1)">Check</button>
      <div class="q-answer" id="q7-ans"><b><span class="ans-correct">✓ 4.</span></b> One LIS is [2, 3, 7, 18] (or [2,5,7,101]) of length 4.</div>
    </div>
  </div>

  <div class="q-card" id="qc8">
    <div class="q-header"><span class="q-num">Q8</span><span class="q-type q-type--msq">MSQ</span><span class="q-diff">★★</span><span class="q-marks">2 marks · no negative</span></div>
    <div class="q-body">Which problems are classically solved by dynamic programming? (Select all.)</div>
    <div class="q-options" id="q8-opts">
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="8" data-val="A"> <span class="q-opt-key">A</span> 0/1 Knapsack</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="8" data-val="B"> <span class="q-opt-key">B</span> Longest Common Subsequence</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="8" data-val="C"> <span class="q-opt-key">C</span> Finding the minimum of an unsorted array</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="8" data-val="D"> <span class="q-opt-key">D</span> Matrix chain multiplication</label>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkMsq(8,['A','B','D'])">Check</button>
      <div class="q-answer" id="q8-ans"><b><span class="ans-correct">✓ (A), (B), (D).</span></b> All have overlapping subproblems. (C) is a single linear scan, not DP.</div>
    </div>
  </div>

  <div class="q-card" id="qc9">
    <div class="q-header"><span class="q-num">Q9</span><span class="q-type q-type--nat">NAT</span><span class="q-diff">★★</span><span class="q-marks">2 marks</span></div>
    <div class="q-body">Coin change: coins &#123;1, 3, 4&#125;, target 6. Minimum number of coins?</div>
    <div class="q-nat"><input class="q-nat__input" id="q9-input" type="number" step="any" placeholder="your answer"><span class="q-nat__label">coins</span></div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(9,1.9,2.1)">Check</button>
      <div class="q-answer" id="q9-ans"><b><span class="ans-correct">✓ 2.</span></b> 6 = 3 + 3 uses 2 coins (better than 4+1+1 = 3 coins).</div>
    </div>
  </div>

  <div class="q-card" id="qc10">
    <div class="q-header"><span class="q-num">Q10</span><span class="q-type">MCQ</span><span class="q-diff">★★</span><span class="q-marks">1 mark</span></div>
    <div class="q-body">Filling the LCS table for strings of lengths $m$ and $n$ takes</div>
    <div class="q-options" id="q10-opts">
      <div class="q-opt" data-q="10" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $O(m+n)$</div>
      <div class="q-opt" data-q="10" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $O(mn)$</div>
      <div class="q-opt" data-q="10" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> $O(2^n)$</div>
      <div class="q-opt" data-q="10" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $O(mn \log n)$</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(10,'mcq','B')">Check</button>
      <div class="q-answer" id="q10-ans"><b><span class="ans-correct">✓ (B) $O(mn)$.</span></b> Each of the $(m+1)(n+1)$ cells is filled in $O(1)$.</div>
    </div>
  </div>

</div><!-- end q-list -->

<div style="margin-top:32px;padding-top:24px;border-top:1px solid var(--gd-border);display:flex;gap:12px;flex-wrap:wrap;">
  <a class="gd-pill-link" href="/module2/2-3-bank.html" style="margin-top:0;">Question Bank (20 Qs) →</a>
  <a class="gd-pill-link" href="/module2.html" style="margin-top:0;">← Module 2 Overview</a>
</div>

<script is:inline slot="scripts">
var scores={};
function updateScore(){document.getElementById('score-num').textContent=Object.values(scores).filter(Boolean).length;}
function selectOpt(el){var q=el.dataset.q;var card=document.getElementById('qc'+q);if(card.classList.contains('q-card--correct')||card.classList.contains('q-card--wrong'))return;document.querySelectorAll('[data-q="'+q+'"].q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected');});el.classList.add('q-opt--selected');}
function check(q,type,correct){var card=document.getElementById('qc'+q);var selected=document.querySelector('[data-q="'+q+'"].q-opt--selected');var ansEl=document.getElementById('q'+q+'-ans');var btn=card.querySelector('.q-check-btn');if(!selected)return;var val=selected.dataset.val;var isCorrect=val===correct;document.querySelectorAll('[data-q="'+q+'"].q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected');if(o.dataset.val===correct)o.classList.add('q-opt--correct');else if(o.dataset.val===val&&!isCorrect)o.classList.add('q-opt--wrong');o.style.pointerEvents='none';});card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');ansEl.style.display='block';btn.disabled=true;scores[q]=isCorrect;updateScore();}
function checkNat(q,min,max){var input=document.getElementById('q'+q+'-input');var ansEl=document.getElementById('q'+q+'-ans');var card=document.getElementById('qc'+q);var btn=card.querySelector('.q-check-btn');var val=parseFloat(input.value);var isCorrect=!isNaN(val)&&val>=min&&val<=max;input.classList.add(isCorrect?'q-nat__input--correct':'q-nat__input--wrong');input.disabled=true;ansEl.style.display='block';btn.disabled=true;card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');scores[q]=isCorrect;updateScore();}
function checkMsq(q,correctArr){var card=document.getElementById('qc'+q);var ansEl=document.getElementById('q'+q+'-ans');var btn=card.querySelector('.q-check-btn');var checked=Array.from(document.querySelectorAll('[data-q="'+q+'"]:checked')).map(function(c){return c.dataset.val;});var isCorrect=correctArr.length===checked.length&&correctArr.every(function(v){return checked.includes(v);});card.querySelectorAll('.q-opt--msq').forEach(function(label){var val=label.querySelector('input').dataset.val;if(correctArr.includes(val))label.classList.add('q-opt--correct');else if(checked.includes(val))label.classList.add('q-opt--wrong');label.querySelector('input').disabled=true;label.style.pointerEvents='none';});card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');ansEl.style.display='block';btn.disabled=true;scores[q]=isCorrect;updateScore();}
function resetAll(){scores={};updateScore();document.querySelectorAll('.q-card').forEach(function(c){c.classList.remove('q-card--correct','q-card--wrong');});document.querySelectorAll('.q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected','q-opt--correct','q-opt--wrong');o.style.pointerEvents='';});document.querySelectorAll('.q-nat__input').forEach(function(i){i.value='';i.disabled=false;i.classList.remove('q-nat__input--correct','q-nat__input--wrong');});document.querySelectorAll('.q-opt--msq input').forEach(function(c){c.checked=false;c.disabled=false;});document.querySelectorAll('.q-opt--msq').forEach(function(l){l.classList.remove('q-opt--correct','q-opt--wrong');l.style.pointerEvents='';});document.querySelectorAll('.q-answer').forEach(function(a){a.style.display='none';});document.querySelectorAll('.q-check-btn').forEach(function(b){b.disabled=false;});}
</script>
</VizLayout>
