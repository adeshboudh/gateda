      <div class="q-opt" data-q="20" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> unsorted</div>
      <div class="q-opt" data-q="20" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> of even length</div>
      <div class="q-opt" data-q="20" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> full of duplicates</div>
