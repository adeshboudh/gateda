<script is:inline slot="scripts">
(function() {
  // ── Data ────────────────────────────────
  const PRESETS = {
    'strong-pos': () => Array.from({length:20}, (_,i) => ({x: i + (Math.random()-0.5)*1.5, y: i*0.9 + (Math.random()-0.5)*1.5})),
    'weak-pos':   () => Array.from({length:20}, (_,i) => ({x: i + (Math.random()-0.5)*3, y: i*0.5 + (Math.random()-0.5)*8})),
    'none':       () => Array.from({length:20}, ()   => ({x: Math.random()*20, y: Math.random()*20})),
    'weak-neg':   () => Array.from({length:20}, (_,i) => ({x: i + (Math.random()-0.5)*3, y: 20 - i*0.5 + (Math.random()-0.5)*8})),
    'strong-neg': () => Array.from({length:20}, (_,i) => ({x: i + (Math.random()-0.5)*1.5, y: 20 - i*0.9 + (Math.random()-0.5)*1.5})),
    'nonlinear':  () => Array.from({length:30}, (_,i) => { const xv = (i/30)*20-10; return {x: xv, y: xv*xv/5 + (Math.random()-0.5)*3}; })
  };

  let points = PRESETS['strong-pos']();

  // ── Statistics — consistent population formulas so r is exact ──
  function stats(pts) {
    if (pts.length < 2) return null;
    const n  = pts.length;
    const mx = d3.mean(pts, d => d.x);
    const my = d3.mean(pts, d => d.y);
    const cov = d3.mean(pts, d => (d.x - mx) * (d.y - my));                     // ÷n
    const sx  = Math.sqrt(d3.mean(pts, d => (d.x - mx) ** 2));                  // ÷n
    const sy  = Math.sqrt(d3.mean(pts, d => (d.y - my) ** 2));                  // ÷n
    const r   = (sx > 0 && sy > 0) ? cov / (sx * sy) : 0;
    return { mx, my, cov, sx, sy, r, n };
  }

  function rColor(r) {
    if (r > 0.7)  return '#4caf82';
    if (r > 0.3)  return '#7c9eff';
    if (r < -0.7) return '#e05c6b';
    if (r < -0.3) return '#f0a44a';
    return '#606880';
  }

  // ── Scales (module-level so drag handler always has current values) ──
  let width, height, x, y, g, M;

  // ── Drag — defined once; does NOT call redraw() so dots are never destroyed mid-drag ──
  const pointDrag = d3.drag()
    .subject(function(event, d) { return { x: x(d.x), y: y(d.y) }; })
    .on('start', function() {
      d3.select(this).raise().attr('stroke-width', 2.5).attr('stroke', 'white');
    })
    .on('drag', function(event, d) {
      d.x = x.invert(event.x);
      d.y = y.invert(event.y);
      d3.select(this).attr('cx', x(d.x)).attr('cy', y(d.y));
      const st = stats(points);
      updateOverlays(st);
      updateStatsDisplay(st);
    })
    .on('end', function() {
      d3.select(this).attr('stroke-width', 1).attr('stroke', 'rgba(255,255,255,0.15)');
      // sync all dot colors to new r
      const st = stats(points);
      if (st) g.select('.dots-g').selectAll('.scatter-dot').attr('fill', rColor(st.r));
    });

  // ── Overlays (regression line + mean crosshairs) — updated independently of dots ──
  function updateOverlays(st) {
    const mg = g.select('.mean-g');
    mg.selectAll('*').remove();
    if (st) {
      mg.append('line')
        .attr('x1', x(st.mx)).attr('x2', x(st.mx)).attr('y1', 0).attr('y2', height)
        .attr('stroke', '#606880').attr('stroke-width', 1).attr('stroke-dasharray', '3 3');
      mg.append('line')
        .attr('x1', 0).attr('x2', width).attr('y1', y(st.my)).attr('y2', y(st.my))
        .attr('stroke', '#606880').attr('stroke-width', 1).attr('stroke-dasharray', '3 3');
    }

    const rg = g.select('.reg-g');
    rg.selectAll('*').remove();
    if (st && st.sx > 0) {
      const slope = st.r * st.sy / st.sx;
      const int   = st.my - slope * st.mx;
      const xd    = x.domain();
      rg.append('line')
        .attr('x1', x(xd[0])).attr('x2', x(xd[1]))
        .attr('y1', y(slope*xd[0]+int)).attr('y2', y(slope*xd[1]+int))
        .attr('stroke', rColor(st.r)).attr('stroke-width', 2).attr('opacity', 0.8);
    }
  }

  function updateStatsDisplay(st) {
    if (!st) return;
    const col = rColor(st.r);
    const rDisp = document.getElementById('r-display');
    rDisp.textContent = `r = ${st.r.toFixed(3)}`;
    rDisp.style.color = col;
    rDisp.style.background = col + '18';
    document.getElementById('ins-r').textContent =
      `r = ${st.r.toFixed(4)} — ${Math.abs(st.r) > 0.7 ? 'strong' : Math.abs(st.r) > 0.3 ? 'moderate' : 'weak'} ` +
      `${st.r > 0 ? 'positive' : st.r < 0 ? 'negative' : 'no'} linear relationship`;
    document.getElementById('ins-cov').textContent = `Cov(X,Y) = ${st.cov.toFixed(3)}`;
    document.getElementById('ins-sx').textContent  = `σX = ${st.sx.toFixed(3)},  σY = ${st.sy.toFixed(3)},  n = ${st.n}`;
    document.getElementById('corr-live').innerHTML =
      `r = <span class="live-val">${st.r.toFixed(3)}</span><br>Cov = <span class="live-val">${st.cov.toFixed(3)}</span>`;
    const warn = document.getElementById('ins-warn');
    if (Math.abs(st.r) < 0.1 && points.length >= 20) {
      warn.style.display = 'block';
      warn.textContent = '⚠ r ≈ 0 does NOT mean X and Y are independent! (See nonlinear preset.)';
    } else {
      warn.style.display = 'none';
    }
  }

  // ── Redraw — D3 join keeps existing dot elements alive (no mid-drag destruction) ──
  function redraw() {
    const st = stats(points);
    updateOverlays(st);

    g.select('.dots-g').selectAll('.scatter-dot')
      .data(points, (d, i) => i)
      .join('circle')
        .attr('class', 'scatter-dot')
        .attr('cx', d => x(d.x)).attr('cy', d => y(d.y))
        .attr('r', 6)
        .attr('fill', st ? rColor(st.r) : '#7c9eff')
        .attr('opacity', 0.75)
        .attr('stroke', 'rgba(255,255,255,0.15)').attr('stroke-width', 1)
        .style('cursor', 'grab')
        .on('contextmenu', function(event, d) {
          event.preventDefault();
          points = points.filter(p => p !== d);
          redraw();
        })
        .call(pointDrag);

    updateStatsDisplay(st);
  }

  // ── Setup — called once + on resize ──
  function setup() {
    const container = document.getElementById('scatter-chart');
    const cW = container.clientWidth || 600;
    const cH = Math.round(cW * 0.6);
    M = { top: 20, right: 20, bottom: 40, left: 52 };
    width  = cW - M.left - M.right;
    height = cH - M.top  - M.bottom;

    d3.select(container).select('svg').remove();
    const svg = d3.select(container).append('svg')
      .attr('viewBox', `0 0 ${cW} ${cH}`)
      .style('width','100%').style('display','block').style('cursor','crosshair');
    g = svg.append('g').attr('transform', `translate(${M.left},${M.top})`);

    x = d3.scaleLinear().domain([-1, 22]).range([0, width]);
    y = d3.scaleLinear().domain([-1, 22]).range([height, 0]);

    // Static: grid + axes
    g.append('g').attr('class','grid')
      .call(d3.axisLeft(y).ticks(5).tickSize(-width).tickFormat(''))
      .call(gr => gr.select('.domain').remove());
    g.append('g').attr('class','grid').attr('transform',`translate(0,${height})`)
      .call(d3.axisBottom(x).ticks(5).tickSize(-height).tickFormat(''))
      .call(gr => gr.select('.domain').remove());
    g.append('g').attr('class','axis').attr('transform',`translate(0,${height})`).call(d3.axisBottom(x).ticks(6));
    g.append('g').attr('class','axis').call(d3.axisLeft(y).ticks(6));

    // Ordered layers: mean → regression → dots (dots on top)
    g.append('g').attr('class', 'mean-g');
    g.append('g').attr('class', 'reg-g');
    g.append('g').attr('class', 'dots-g');

    svg.on('dblclick', function(event) {
      const [mx, my] = d3.pointer(event, g.node());
      points.push({ x: x.invert(mx), y: y.invert(my) });
      redraw();
    });

    redraw();
  }

  // ── Controls ──
  document.querySelector('.preset-grid').addEventListener('click', e => {
    const btn = e.target.closest('.preset-btn');
    if (!btn || !PRESETS[btn.dataset.preset]) return;
    points = PRESETS[btn.dataset.preset]();
    redraw();
  });
  document.getElementById('add-point-btn').addEventListener('click', () => {
    points.push({ x: Math.random() * 20, y: Math.random() * 20 });
    redraw();
  });
  document.getElementById('clear-btn').addEventListener('click', () => {
    points = [];
    redraw();
    document.getElementById('r-display').textContent = 'r = —';
    document.getElementById('r-display').style.color = '';
    document.getElementById('r-display').style.background = '';
  });

  setup();
  window.addEventListener('resize', () => setTimeout(setup, 150));
})();
</script>
</VizLayout>
