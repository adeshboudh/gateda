    <span class="gd-page-nav__title">Module 1 Complete</span>
  </a>
</div>

<script is:inline slot="scripts">
// Normal CDF (Abramowitz & Stegun)
function Phi(x) {
  const t = 1/(1+0.2316419*Math.abs(x));
  const d = 0.3989423*Math.exp(-x*x/2);
  const p = d*t*(0.3193815+t*(-0.3565638+t*(1.7814779+t*(-1.8212560+t*1.3302744))));
  return x >= 0 ? 1-p : p;
}
function normalPDF(x, mu=0, s=1) { return Math.exp(-0.5*((x-mu)/s)**2)/(s*Math.sqrt(2*Math.PI)); }
function invPhi(p) {
  // Rational approximation
  function rationalApprox(t) {
    const c = [2.515517, 0.802853, 0.010328];
    const d = [1.432788, 0.189269, 0.001308];
    return t-(c[0]+c[1]*t+c[2]*t*t)/(1+d[0]*t+d[1]*t*t+d[2]*t*t*t);
  }
  if (p < 0.5) return -rationalApprox(Math.sqrt(-2*Math.log(p)));
  return rationalApprox(Math.sqrt(-2*Math.log(1-p)));
}

const ALPHA_OPTS = [
  { a: 0.10, label: '0.10' },
  { a: 0.05, label: '0.05' },
  { a: 0.025, label: '0.025' },
  { a: 0.01, label: '0.01' }
];

let delta = 1.5, alphaIdx = 1;

// ── VIZ 1 ────────────────────────────────
function drawErrorChart() {
  const container = document.getElementById('error-chart');
  const cW = container.clientWidth || 560;
  const cH = Math.round(cW * 0.5);
  const M = { top: 22, right: 24, bottom: 44, left: 54 };
  const W = cW - M.left - M.right;
  const H = cH - M.top  - M.bottom;

  d3.select(container).select('svg').remove();
  const svg = d3.select(container).append('svg')
    .attr('viewBox',`0 0 ${cW} ${cH}`).style('width','100%').style('height','auto');
  const g = svg.append('g').attr('transform',`translate(${M.left},${M.top})`);

  const alpha = ALPHA_OPTS[alphaIdx].a;
  const zstar = invPhi(1 - alpha);  // one-tailed critical value
  const H1mu  = delta;

  const xRange = [-3.5, delta + 3.5];
  const x = d3.scaleLinear().domain(xRange).range([0,W]);
  const pts  = d3.range(xRange[0], xRange[1]+0.02, 0.05);
  const yMax = normalPDF(0, 0, 1) * 1.15;
  const y    = d3.scaleLinear().domain([0, yMax]).range([H, 0]);

  // Grid
  g.append('g').attr('class','grid')
    .call(d3.axisLeft(y).ticks(4).tickSize(-W).tickFormat(''))
    .call(gr => gr.select('.domain').remove());

  // Fill: α region (under H0 beyond zstar) — red
  const alphaArea = d3.area().x(d=>x(d)).y0(H).y1(d => y(normalPDF(d,0,1)))
    .curve(d3.curveBasis);
  const alphaPts = pts.filter(p => p >= zstar);
  g.append('path').datum(alphaPts).attr('d', alphaArea).attr('fill','#e05c6b').attr('opacity',0.4);

  // Fill: β region (under H1 below zstar) — orange
  const betaArea = d3.area().x(d=>x(d)).y0(H).y1(d=>y(normalPDF(d,H1mu,1))).curve(d3.curveBasis);
  const betaPts = pts.filter(p => p <= zstar);
  g.append('path').datum(betaPts).attr('d', betaArea).attr('fill','#f0a44a').attr('opacity',0.35);

  // Fill: power region (under H1 beyond zstar) — green
  const powerArea = d3.area().x(d=>x(d)).y0(H).y1(d=>y(normalPDF(d,H1mu,1))).curve(d3.curveBasis);
  const powerPts = pts.filter(p => p >= zstar);
  g.append('path').datum(powerPts).attr('d', powerArea).attr('fill','#4caf82').attr('opacity',0.35);

  // H0 curve
  const lineH0 = d3.line().x(d=>x(d)).y(d=>y(normalPDF(d,0,1))).curve(d3.curveBasis);
  g.append('path').datum(pts).attr('d',lineH0).attr('fill','none').attr('stroke','#7c9eff').attr('stroke-width',2);

  // H1 curve
  const lineH1 = d3.line().x(d=>x(d)).y(d=>y(normalPDF(d,H1mu,1))).curve(d3.curveBasis);
  g.append('path').datum(pts).attr('d',lineH1).attr('fill','none').attr('stroke','#4caf82').attr('stroke-width',2);

  // Critical line
  g.append('line').attr('x1',x(zstar)).attr('x2',x(zstar)).attr('y1',0).attr('y2',H)
    .attr('stroke','#fff').attr('stroke-width',1.5).attr('stroke-dasharray','5 3');
  g.append('text').attr('x',x(zstar)+3).attr('y',12).attr('fill','#fff').attr('font-size',10)
    .text(`z*=${zstar.toFixed(2)}`);

  // Labels
  g.append('text').attr('x',x(0)).attr('y',y(yMax*0.97)).attr('text-anchor','middle')
    .attr('fill','#7c9eff').attr('font-size',10).attr('font-weight','700').text('H₀ (μ=0)');
  if (H1mu <= xRange[1]-0.5)
    g.append('text').attr('x',x(H1mu)).attr('y',y(yMax*0.97)).attr('text-anchor','middle')
      .attr('fill','#4caf82').attr('font-size',10).attr('font-weight','700').text(`H₁ (μ=${H1mu.toFixed(1)})`);

  // Region labels
  if (zstar < xRange[1]-0.3)
    g.append('text').attr('x',(x(zstar)+W)/2).attr('y',H*0.6).attr('text-anchor','middle')
      .attr('fill','#e05c6b').attr('font-size',9).text('α');
  g.append('text').attr('x',(x(xRange[0])+x(zstar))/2).attr('y',H*0.72).attr('text-anchor','middle')
    .attr('fill','#f0a44a').attr('font-size',9).text('β');
  if (zstar < xRange[1]-0.3)
    g.append('text').attr('x',(x(zstar)+W)/2).attr('y',H*0.45).attr('text-anchor','middle')
      .attr('fill','#4caf82').attr('font-size',9).text('Power');

  g.append('g').attr('class','axis').attr('transform',`translate(0,${H})`).call(d3.axisBottom(x).ticks(8));
  g.append('g').attr('class','axis').call(d3.axisLeft(y).ticks(4).tickFormat(d3.format('.2f')));

  // Compute values
  const alphaVal = alpha;
  const betaVal  = Phi(zstar - H1mu);
  const power    = 1 - betaVal;

  document.getElementById('alpha-val').textContent  = (alphaVal*100).toFixed(1)+'%';
  document.getElementById('beta-val').textContent   = (betaVal*100).toFixed(1)+'%';
  document.getElementById('power-val').textContent  = (power*100).toFixed(1)+'%';
  document.getElementById('zstar-val').textContent  = zstar.toFixed(2);
  document.getElementById('error-live').innerHTML   =
    `α=${(alphaVal*100).toFixed(1)}% · β=${(betaVal*100).toFixed(1)}%<br>Power = <span class="live-val">${(power*100).toFixed(1)}%</span>`;
  document.getElementById('ins-tradeoff').textContent =
    `With α=${(alphaVal*100).toFixed(0)}% and effect δ=${H1mu.toFixed(1)}σ: power=${(power*100).toFixed(0)}%. ` +
    (power < 0.5 ? 'Underpowered — increase n or effect size.' : power > 0.8 ? 'Good power (>80%).' : 'Moderate power.');
  document.getElementById('ins-practical').textContent =
    `Reducing α from 0.05 → 0.01 moves z* right → power drops from ${(100*(1-Phi(invPhi(0.95)-H1mu))).toFixed(0)}% to ${(100*(1-Phi(invPhi(0.99)-H1mu))).toFixed(0)}%. Same data, harder to detect effect.`;
}

document.getElementById('delta-slider').addEventListener('input', function() {
  delta = +this.value; document.getElementById('delta-val').textContent = delta.toFixed(1); drawErrorChart();
});
document.getElementById('alpha-slider-ctrl').addEventListener('input', function() {
  alphaIdx = +this.value - 1;
  document.getElementById('alpha-slider-val').textContent = ALPHA_OPTS[alphaIdx].label;
  drawErrorChart();
});

drawErrorChart();

// ── VIZ 2: P-VALUE ───────────────────────
let zObs = 1.96;
let _pG, _pX, _pY, _pW, _pH;  // persistent SVG state — never destroyed during drag

function initPvalChart() {
  const container = document.getElementById('pval-chart');
  const cW = container.clientWidth || 560;
  const cH = Math.round(cW * 0.44);
  const M = { top: 20, right: 20, bottom: 44, left: 54 };
  _pW = cW - M.left - M.right;
  _pH = cH - M.top - M.bottom;
  const W = _pW, H = _pH;

  d3.select(container).select('svg').remove();
  const svg = d3.select(container).append('svg')
    .attr('viewBox',`0 0 ${cW} ${cH}`).style('width','100%').style('height','auto')
    .style('cursor','ew-resize');
  _pG = svg.append('g').attr('transform',`translate(${M.left},${M.top})`);

  const xRange = [-4, 4];
  _pX = d3.scaleLinear().domain(xRange).range([0, W]);
  const yMax = normalPDF(0,0,1)*1.15;
  _pY = d3.scaleLinear().domain([0, yMax]).range([H, 0]);
  const x = _pX, y = _pY, g = _pG;
  const pts = d3.range(-4, 4.02, 0.04);

  // Grid
  g.append('g').attr('class','grid')
    .call(d3.axisLeft(y).ticks(4).tickSize(-W).tickFormat(''))
    .call(gr => gr.select('.domain').remove());

  // Tail area — updated in-place by updatePvalChart
  g.append('path').attr('class','pval-tail');

  // Normal curve (static)
  const line = d3.line().x(d=>x(d)).y(d=>y(normalPDF(d,0,1))).curve(d3.curveBasis);
  g.append('path').datum(pts).attr('d',line)
    .attr('fill','none').attr('stroke','#7c9eff').attr('stroke-width',2);

  // z-line — updated in-place
  g.append('line').attr('class','pval-zline').attr('y1',0).attr('y2',H)
    .attr('stroke','#fff').attr('stroke-width',2).style('cursor','ew-resize');

  // α reference lines (static)
  [1.645, 1.96, 2.576].forEach(zc => {
    g.append('line').attr('x1',x(zc)).attr('x2',x(zc)).attr('y1',0).attr('y2',H)
      .attr('stroke','rgba(240,164,74,0.5)').attr('stroke-width',1).attr('stroke-dasharray','3 2');
  });
  g.append('text').attr('x',x(1.96)+3).attr('y',H*0.15)
    .attr('fill','rgba(240,164,74,0.8)').attr('font-size',9).text('1.96(α=.05)');

  // z label — updated in-place
  g.append('text').attr('class','pval-zlabel')
    .attr('y',H+20).attr('text-anchor','middle').attr('fill','#fff').attr('font-size',10);

  // Draggable circle — persists across updates; drag defined once here
  const dragBehavior = d3.drag()
    .on('drag', function(event) {
      const xNew = Math.max(0, Math.min(W, event.x));
      zObs = x.invert(xNew);
      document.getElementById('zobs-slider').value = zObs;
      document.getElementById('zobs-val').textContent = zObs.toFixed(2);
      updatePvalChart();  // update in-place — no SVG destroy
    });

  g.append('circle').attr('class','pval-drag-circle')
    .attr('cy', H+2).attr('r',7)
    .attr('fill','#7c9eff').attr('stroke','#fff').attr('stroke-width',1.5)
    .style('cursor','ew-resize')
    .call(dragBehavior);

  // Axes
  g.append('g').attr('class','axis').attr('transform',`translate(0,${H})`)
    .call(d3.axisBottom(x).ticks(8));
  g.append('g').attr('class','axis')
    .call(d3.axisLeft(y).ticks(4).tickFormat(d3.format('.3f')));

  updatePvalChart();
}

function updatePvalChart() {
  const g = _pG, x = _pX, y = _pY, H = _pH;
  const pts = d3.range(-4, 4.02, 0.04);

  // Tail area
  const pArea = d3.area().x(d=>x(d)).y0(H).y1(d=>y(normalPDF(d,0,1))).curve(d3.curveBasis);
  const pPts = zObs >= 0 ? pts.filter(p => p >= zObs) : pts.filter(p => p <= zObs);
  g.select('.pval-tail').datum(pPts).attr('d', pArea).attr('fill','#7c9eff').attr('opacity',0.45);

  // z-line and drag circle
  g.select('.pval-zline').attr('x1',x(zObs)).attr('x2',x(zObs));
  g.select('.pval-drag-circle').attr('cx', x(zObs));
  g.select('.pval-zlabel').attr('x', x(zObs)).text(`z=${zObs.toFixed(2)}`);

  // p-value display
  const pval = zObs >= 0 ? 1 - Phi(zObs) : Phi(zObs);
  const reject = pval < 0.05;
  const disp = document.getElementById('pval-display');
  disp.textContent = `p = ${pval.toFixed(4)}`;
  disp.style.color = reject ? '#4caf82' : '#e05c6b';
  disp.style.borderColor = reject ? 'rgba(76,175,130,0.4)' : 'rgba(224,92,107,0.4)';
  disp.innerHTML += `<span class="decision-tag" style="background:${reject?'rgba(76,175,130,0.15)':'rgba(224,92,107,0.12)'};color:${reject?'#4caf82':'#e05c6b'}">${reject ? 'Reject H₀' : 'Fail to Reject H₀'}</span>`;

  document.getElementById('pval-live').innerHTML =
    `P(Z ≥ ${zObs.toFixed(2)}) = 1 - Φ(${zObs.toFixed(2)}) = <span class="live-val">${pval.toFixed(4)}</span>`;
}

document.getElementById('zobs-slider').addEventListener('input', function() {
  zObs = +this.value;
  document.getElementById('zobs-val').textContent = zObs.toFixed(2);
  updatePvalChart();
});

initPvalChart();
window.addEventListener('resize', () => setTimeout(() => { drawErrorChart(); initPvalChart(); }, 150));
</script>
</VizLayout>
