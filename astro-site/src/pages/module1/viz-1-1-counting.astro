  <script is:inline slot="scripts">
// ── VIZ 1: VENN ─────────────────────────
(function() {
  let nA = 40, nB = 35, nAB = 10, N = 100;

  function clampAB() { nAB = Math.min(nAB, nA, nB, N - nA - nB + nAB); nAB = Math.max(0, nAB); }

  // Exact area of lens formed by two intersecting circles
  function lensArea(r1, r2, d) {
    if (d >= r1 + r2) return 0;
    if (d <= Math.abs(r1 - r2)) return Math.PI * Math.min(r1, r2) * Math.min(r1, r2);
    const c1 = Math.max(-1, Math.min(1, (d*d + r1*r1 - r2*r2) / (2*d*r1)));
    const c2 = Math.max(-1, Math.min(1, (d*d + r2*r2 - r1*r1) / (2*d*r2)));
    const a1 = r1*r1 * Math.acos(c1);
    const a2 = r2*r2 * Math.acos(c2);
    const s = (-d+r1+r2)*(d+r1-r2)*(d-r1+r2)*(d+r1+r2);
    return a1 + a2 - 0.5 * Math.sqrt(Math.max(0, s));
  }

  // Binary-search distance d that gives target lens area
  function findD(r1, r2, targetArea) {
    if (targetArea <= 0) return r1 + r2 + 1;
    const maxA = Math.PI * Math.min(r1, r2) * Math.min(r1, r2);
    if (targetArea >= maxA) return Math.abs(r1 - r2);
    let lo = Math.abs(r1 - r2), hi = r1 + r2;
    for (let i = 0; i < 64; i++) {
      const mid = (lo + hi) / 2;
      if (lensArea(r1, r2, mid) > targetArea) lo = mid; else hi = mid;
    }
    return (lo + hi) / 2;
  }

  function drawVenn() {
    clampAB();
    const pa = nA/N, pb = nB/N, pab = nAB/N, paub = (nA+nB-nAB)/N;
    const container = document.getElementById('venn-chart');
    const cW = container.clientWidth || 560;
    const cH = Math.round(cW * 0.55);
    d3.select(container).select('svg').remove();

    const svg = d3.select(container).append('svg')
      .attr('viewBox', `0 0 ${cW} ${cH}`)
      .style('width','100%').style('height','auto');

    const cx = cW/2, cy = cH/2;

    // Circle areas ∝ P(A), P(B) — baseR is reference radius for P=1
    const baseR = Math.min(cH * 0.42, cW * 0.32);
    const rA0 = baseR * Math.sqrt(pa);
    const rB0 = baseR * Math.sqrt(pb);

    // Find d so lens area / (π·baseR²) = pab  →  lens area = π·baseR²·pab
    const rawD = findD(rA0, rB0, Math.PI * baseR * baseR * pab);

    // Uniform scale to fit canvas (preserves all proportions)
    const pad = 32;
    const s = Math.min(cW / (rawD + rA0 + rB0 + pad*2), cH / (2*Math.max(rA0,rB0) + pad*2), 1);
    const rA = rA0*s, rB = rB0*s, d = rawD*s;
    const xA = cx - d/2, xB = cx + d/2;

    svg.append('rect').attr('width', cW).attr('height', cH).attr('fill', '#0f1117');

    svg.append('circle').attr('cx', xA).attr('cy', cy).attr('r', rA)
      .attr('fill', '#7c9eff').attr('opacity', 0.25).attr('stroke', '#7c9eff').attr('stroke-width', 1.5);
    svg.append('circle').attr('cx', xB).attr('cy', cy).attr('r', rB)
      .attr('fill', '#6ee7a8').attr('opacity', 0.20).attr('stroke', '#6ee7a8').attr('stroke-width', 1.5);

    const intX = (xA + xB) / 2;
    const fs = Math.max(11, cW*0.025);
    const hasOverlap = nAB > 0 && d < rA + rB;

    svg.append('text').attr('x', xA - rA*0.5).attr('y', cy + 4)
      .attr('text-anchor','middle').attr('fill','#7c9eff').attr('font-size', fs).attr('font-weight','700').text('A');
    svg.append('text').attr('x', xB + rB*0.5).attr('y', cy + 4)
      .attr('text-anchor','middle').attr('fill','#6ee7a8').attr('font-size', fs).attr('font-weight','700').text('B');
    if (hasOverlap) {
      svg.append('text').attr('x', intX).attr('y', cy + 4)
        .attr('text-anchor','middle').attr('fill','#f5c46b')
        .attr('font-size', Math.max(10, cW*0.022)).attr('font-weight','600').text('A∩B');
    }

    svg.append('text').attr('x', xA - rA*0.65).attr('y', cy - rA*0.55)
      .attr('text-anchor','middle').attr('fill','#7c9eff').attr('font-size', 11)
      .text(`P(A)=${pa.toFixed(2)}`);
    svg.append('text').attr('x', xB + rB*0.65).attr('y', cy - rB*0.55)
      .attr('text-anchor','middle').attr('fill','#6ee7a8').attr('font-size', 11)
      .text(`P(B)=${pb.toFixed(2)}`);
    if (nAB > 0) {
      svg.append('text').attr('x', intX).attr('y', cy + Math.max(rA,rB)*0.65)
        .attr('text-anchor','middle').attr('fill','#f5c46b').attr('font-size', 11)
        .text(`P(A∩B)=${pab.toFixed(2)}`);
    }
    svg.append('text').attr('x', 12).attr('y', 18)
      .attr('fill','#6b7384').attr('font-size', 11).text('Ω (N=100)');

    document.getElementById('pA').textContent   = pa.toFixed(3);
    document.getElementById('pB').textContent   = pb.toFixed(3);
    document.getElementById('pAB').textContent  = pab.toFixed(3);
    document.getElementById('pAuB').textContent = paub.toFixed(3);
    document.getElementById('venn-live').innerHTML =
      `P(A∪B) = ${pa.toFixed(2)} + ${pb.toFixed(2)} − ${pab.toFixed(2)}<br>` +
      `= <span class="live-val">${paub.toFixed(3)}</span>`;
    document.getElementById('venn-ins').textContent =
      `P(A∪B) = ${(paub*100).toFixed(0)}% of outcomes fall in A or B (or both).`;
    document.getElementById('venn-ins2').style.display = nAB === 0 ? 'block' : 'none';
  }

  [['nA', v => nA=v, 'nA-val'], ['nB', v => nB=v, 'nB-val'], ['nAB', v => nAB=v, 'nAB-val']]
    .forEach(([id, set, valId]) => {
      document.getElementById(id).addEventListener('input', function() {
        set(+this.value); document.getElementById(valId).textContent = this.value; drawVenn();
      });
    });

  drawVenn();
  window.addEventListener('resize', () => setTimeout(drawVenn, 150));
})();

// ── VIZ 2: nPr / nCr ────────────────────
(function() {
  let n = 8, r = 3;

  function factorial(k) {
    if (k <= 1) return 1;
    let res = 1; for (let i = 2; i <= k; i++) res *= i; return res;
  }
  function pnr(n,r) { return factorial(n) / factorial(n-r); }
  function cnr(n,r) { return factorial(n) / (factorial(r) * factorial(n-r)); }

  function update() {
    r = Math.min(r, n);
    document.getElementById('r-slider').max = n;
    document.getElementById('r-slider').value = r;
    document.getElementById('r-val').textContent = r;

    const P = pnr(n,r), C = cnr(n,r);
    document.getElementById('pnr-val').textContent = P.toLocaleString();
    document.getElementById('cnr-val').textContent = C.toLocaleString();
    document.getElementById('pnr-formula').textContent = `${n}! / (${n-r})! = ${n}×${n-1}×...×${n-r+1}`;
    document.getElementById('cnr-formula').textContent = `${n}! / (${r}! × ${n-r}!) = P/${factorial(r)} = ${C}`;
    document.getElementById('combo-live').innerHTML =
      `P/C = r! = ${r}! = <span class="live-val">${factorial(r)}</span><br>` +
      `(${factorial(r)} orderings of the same ${r} items collapse to 1 combination)`;

    const grid = document.getElementById('item-grid');
    grid.innerHTML = '';
    for (let i = 0; i < n; i++) {
      const dot = document.createElement('div');
      dot.className = 'item-dot';
      dot.textContent = i + 1;
      if (i < r) {
        dot.style.background = 'rgba(124,158,255,0.2)';
        dot.style.border = '2px solid #7c9eff';
        dot.style.color = '#7c9eff';
      } else {
        dot.style.background = 'var(--gd-bg-3)';
        dot.style.border = '1px solid var(--gd-line)';
        dot.style.color = 'var(--gd-text-2)';
      }
      grid.appendChild(dot);
    }
  }

  document.getElementById('n-slider').addEventListener('input', function() {
    n = +this.value; document.getElementById('n-val').textContent = n; update();
  });
  document.getElementById('r-slider').addEventListener('input', function() {
    r = +this.value; document.getElementById('r-val').textContent = r; update();
  });

  update();
})();
  </script>
</VizLayout>
