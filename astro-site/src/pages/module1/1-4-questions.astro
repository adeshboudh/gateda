---
import VizLayout from '../../layouts/VizLayout.astro';
const title = "1.4 Practice Questions · GATE DA";
---
<VizLayout {title} currentPath="/module1/1-4-questions" pageCss="/assets/css/pages/1-1-questions.css">

<div class="gd-breadcrumb">
  <a href="/index.html">Home</a><span>›</span>
  <a href="/module1/index.html">Module 1</a><span>›</span>
  1.4 Questions
</div>
<a class="gd-pill-link" href="/module1/viz-1-4-distributions.html">← Theory &amp; Visualizations</a>

<div class="gd-viz-header">
  <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;">
    <span class="gd-badge gd-badge--subject">Module 1 · P&amp;S</span>
    <span class="gd-badge gd-badge--pyq">10 questions · MCQ / NAT / MSQ</span>
  </div>
  <h1 id="top">1.4 Practice Questions — Discrete Distributions</h1>
  <p>GATE-style questions on Bernoulli, Binomial, and Poisson. Know which distribution to use — identification is half the battle.</p>
</div>

<div class="q-score-bar">
  <div>
    <div class="q-score-bar__count"><span id="score-num">0</span> / 10</div>
    <div class="q-score-bar__label">correct answers revealed</div>
  </div>
  <button class="q-score-bar__reset" onclick="resetAll()">Reset all</button>
</div>

<div class="q-list">

  <!-- Q1 -->
  <div class="q-card" id="qc1">
    <div class="q-header">
      <span class="q-num">Q1</span>
      <span class="q-type">MCQ</span>
      <span class="q-diff">★</span>
      <span class="q-marks">1 mark</span>
    </div>
    <div class="q-body">If $X \sim \text&#123;Bernoulli&#125;(0.6)$, then $\mathrm&#123;Var&#125;(X) =$</div>
    <div class="q-options" id="q1-opts">
      <div class="q-opt" data-q="1" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> 0.6</div>
      <div class="q-opt" data-q="1" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> 0.24</div>
      <div class="q-opt" data-q="1" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> 0.4</div>
      <div class="q-opt" data-q="1" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> 0.36</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(1,'mcq','B')">Check</button>
      <div class="q-answer" id="q1-ans">
        <b><span class="ans-correct">✓ (B) 0.24.</span></b>
        $\mathrm&#123;Var&#125; = p(1-p) = 0.6 \times 0.4 = 0.24$. Traps: (A) 0.6 = $p$ = the mean, not the variance. (C) 0.4 = $1-p$. (D) 0.36 = $p^2$ — no formula produces this.
      </div>
    </div>
  </div>

  <!-- Q2 -->
  <div class="q-card" id="qc2">
    <div class="q-header">
      <span class="q-num">Q2</span>
      <span class="q-type q-type--nat">NAT</span>
      <span class="q-diff">★★</span>
      <span class="q-marks">2 marks · no negative</span>
    </div>
    <div class="q-body">If $X \sim \text&#123;Binomial&#125;(20, 0.3)$, then $\mathrm&#123;Var&#125;(X) =$ ___ (one decimal).</div>
    <div class="q-nat">
      <input type="number" class="q-nat__input" id="q2-input" step="0.1" placeholder="0.0">
      <span class="q-nat__label">one decimal place</span>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(2,4.1,4.3)">Check</button>
      <div class="q-answer" id="q2-ans">
        <b><span class="ans-correct">✓ 4.2.</span></b>
        $\mathrm&#123;Var&#125; = np(1-p) = 20 \times 0.3 \times 0.7 = 4.2$. (Mean would be $np = 6$ — don't confuse the two.)
      </div>
    </div>
  </div>

  <!-- Q3 -->
  <div class="q-card" id="qc3">
    <div class="q-header">
      <span class="q-num">Q3</span>
      <span class="q-type">MCQ</span>
      <span class="q-diff">★★</span>
      <span class="q-ref">2025 Q40</span>
      <span class="q-marks">2 marks</span>
    </div>
    <div class="q-body">Let $Y = \sum_&#123;i=1&#125;^&#123;300&#125; X_i$ with $X_i \sim$ i.i.d. Bernoulli(0.25). Using the CLT, $P(60 \le Y \le 90) \approx$ (where $\Phi$ = standard normal CDF)</div>
    <div class="q-options" id="q3-opts">
      <div class="q-opt" data-q="3" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> $\Phi(2) - \Phi(-2)$</div>
      <div class="q-opt" data-q="3" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> $\Phi(1) - \Phi(-1)$</div>
      <div class="q-opt" data-q="3" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> $\Phi(3) - \Phi(-3)$</div>
      <div class="q-opt" data-q="3" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> $\Phi(90) - \Phi(60)$</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(3,'mcq','A')">Check</button>
      <div class="q-answer" id="q3-ans">
        <b><span class="ans-correct">✓ (A) $\Phi(2)-\Phi(-2)$.</span></b>
        $Y\sim\text&#123;Binom&#125;(300,0.25)$: mean $np=75$, variance $np(1-p)=56.25$, SD $=7.5$. Standardise: $(60-75)/7.5 = -2$, $(90-75)/7.5 = 2$. So $P \approx \Phi(2)-\Phi(-2)$.
      </div>
    </div>
  </div>

  <!-- Q4 -->
  <div class="q-card" id="qc4">
    <div class="q-header">
      <span class="q-num">Q4</span>
      <span class="q-type q-type--nat">NAT</span>
      <span class="q-diff">★★</span>
      <span class="q-marks">2 marks · no negative</span>
    </div>
    <div class="q-body">Typos occur at a Poisson rate of 2 per page. The probability that a given page has <strong>no</strong> typo is ___ (three decimals). Use $e^&#123;-2&#125; \approx 0.135$.</div>
    <div class="q-nat">
      <input type="number" class="q-nat__input" id="q4-input" step="0.001" placeholder="0.000">
      <span class="q-nat__label">three decimal places</span>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(4,0.130,0.140)">Check</button>
      <div class="q-answer" id="q4-ans">
        <b><span class="ans-correct">✓ 0.135.</span></b>
        Poisson($\lambda=2$): general formula $P(X=k)=e^&#123;-\lambda&#125;\lambda^k/k!$. At $k=0$: $P(X=0)=e^&#123;-2&#125;\cdot2^0/1=e^&#123;-2&#125;\approx0.135$. Events at constant rate with independence → Poisson is the right model.
      </div>
    </div>
  </div>

  <!-- Q5 -->
  <div class="q-card" id="qc5">
    <div class="q-header">
      <span class="q-num">Q5</span>
      <span class="q-type">MCQ</span>
      <span class="q-diff">★★</span>
      <span class="q-marks">2 marks</span>
    </div>
    <div class="q-body">A machine makes items with defect probability 0.002. In a batch of 1000 (large $n$, small $p$), the probability of <strong>exactly 3</strong> defectives (Poisson approximation) is closest to</div>
    <div class="q-options" id="q5-opts">
      <div class="q-opt" data-q="5" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> 0.180</div>
      <div class="q-opt" data-q="5" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> 0.090</div>
      <div class="q-opt" data-q="5" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> 0.270</div>
      <div class="q-opt" data-q="5" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> 0.050</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(5,'mcq','A')">Check</button>
      <div class="q-answer" id="q5-ans">
        <b><span class="ans-correct">✓ (A) 0.180.</span></b>
        Poisson approx valid: $n=1000$ large, $p=0.002$ small, $np=2$ moderate. $\lambda=np=2$. $P(X=3)=e^&#123;-2&#125;\cdot2^3/3!=e^&#123;-2&#125;\cdot8/6\approx0.135\times1.333\approx0.180$. Rule of thumb: use Poisson when $n\ge20$ and $p\le0.05$.
      </div>
    </div>
  </div>

  <!-- Q6 -->
  <div class="q-card" id="qc6">
    <div class="q-header">
      <span class="q-num">Q6</span>
      <span class="q-type">MCQ</span>
      <span class="q-diff">★★★</span>
      <span class="q-ref">2026 Q44</span>
      <span class="q-marks">2 marks</span>
    </div>
    <div class="q-body">$X \sim \text&#123;Bernoulli&#125;(0.3)$ and $Y \sim \text&#123;Normal&#125;(0, 100)$ are independent. Then $\mathrm&#123;Var&#125;((2X-1)Y) =$</div>
    <div class="q-options" id="q6-opts">
      <div class="q-opt" data-q="6" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> 100</div>
      <div class="q-opt" data-q="6" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> 90</div>
      <div class="q-opt" data-q="6" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> 49</div>
      <div class="q-opt" data-q="6" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> 21</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(6,'mcq','A')">Check</button>
      <div class="q-answer" id="q6-ans">
        <b><span class="ans-correct">✓ (A) 100.</span></b>
        $(2X-1) \in &#123;-1,+1&#125;$ so $(2X-1)^2 = 1$ always. With $E[Y]=0$: $E[(2X-1)Y] = E[2X-1]\cdot E[Y] = 0$ (independence). $\mathrm&#123;Var&#125; = E[(2X-1)^2 Y^2] = E[(2X-1)^2]\cdot E[Y^2] = 1 \times 100 = 100$.
      </div>
    </div>
  </div>

  <!-- Q7 -->
  <div class="q-card" id="qc7">
    <div class="q-header">
      <span class="q-num">Q7</span>
      <span class="q-type q-type--nat">NAT</span>
      <span class="q-diff">★★</span>
      <span class="q-marks">2 marks · no negative</span>
    </div>
    <div class="q-body">A process produces 5% defectives. In 20 independent items, the probability of <strong>at least one</strong> defective is ___ (two decimals). Use $0.95^&#123;20&#125; \approx 0.358$.</div>
    <div class="q-nat">
      <input type="number" class="q-nat__input" id="q7-input" step="0.01" placeholder="0.00">
      <span class="q-nat__label">two decimal places</span>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(7,0.62,0.66)">Check</button>
      <div class="q-answer" id="q7-ans">
        <b><span class="ans-correct">✓ 0.64.</span></b>
        $P(\text&#123;at least one&#125;) = 1 - P(\text&#123;none&#125;) = 1 - (0.95)^&#123;20&#125; \approx 1 - 0.358 = 0.642 \approx 0.64$.
      </div>
    </div>
  </div>

  <!-- Q8 -->
  <div class="q-card" id="qc8">
    <div class="q-header">
      <span class="q-num">Q8</span>
      <span class="q-type q-type--msq">MSQ</span>
      <span class="q-diff">★★</span>
      <span class="q-marks">2 marks · no negative</span>
    </div>
    <div class="q-body">Which statements are TRUE? (Select all that apply.)</div>
    <div class="q-options" id="q8-opts">
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="8" data-val="A"> <span class="q-opt-key">A</span> For Binomial($n,p$), the mean is $np$.</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="8" data-val="B"> <span class="q-opt-key">B</span> For Poisson($\lambda$), mean = variance = $\lambda$.</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="8" data-val="C"> <span class="q-opt-key">C</span> The sum of two independent Poisson($\lambda_1$), Poisson($\lambda_2$) is Poisson($\lambda_1+\lambda_2$).</label>
      <label class="q-opt q-opt--msq"><input type="checkbox" data-q="8" data-val="D"> <span class="q-opt-key">D</span> For Binomial($n,p$), the variance is $np$.</label>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkMsq(8,['A','B','C'])">Check</button>
      <div class="q-answer" id="q8-ans">
        <b><span class="ans-correct">✓ (A), (B), (C).</span></b><br>
        (D) is <span class="ans-wrong">False</span> — binomial variance is $np(1-p)$, not $np$. (A)–(C) are standard results. The Poisson additivity (C) follows from the MGF.
      </div>
    </div>
  </div>

  <!-- Q9 -->
  <div class="q-card" id="qc9">
    <div class="q-header">
      <span class="q-num">Q9</span>
      <span class="q-type">MCQ</span>
      <span class="q-diff">★★</span>
      <span class="q-marks">2 marks</span>
    </div>
    <div class="q-body">A fair coin is tossed repeatedly. $X$ = number of tosses until the <strong>first Head</strong> (Geometric, $p=0.5$). Then $P(X \ge 3) =$</div>
    <div class="q-options" id="q9-opts">
      <div class="q-opt" data-q="9" data-val="A" onclick="selectOpt(this)"><span class="q-opt-key">A</span> 1/8</div>
      <div class="q-opt" data-q="9" data-val="B" onclick="selectOpt(this)"><span class="q-opt-key">B</span> 1/4</div>
      <div class="q-opt" data-q="9" data-val="C" onclick="selectOpt(this)"><span class="q-opt-key">C</span> 3/8</div>
      <div class="q-opt" data-q="9" data-val="D" onclick="selectOpt(this)"><span class="q-opt-key">D</span> 1/2</div>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="check(9,'mcq','B')">Check</button>
      <div class="q-answer" id="q9-ans">
        <b><span class="ans-correct">✓ (B) 1/4.</span></b>
        Geometric survival formula: $P(X\ge k) = (1-p)^&#123;k-1&#125;$. So $P(X\ge3)=(0.5)^2=1/4$. Intuition: "need at least 3 tosses" means the first two must both be Tails — $P(TT)=(1/2)^2$.
        <br>Reference: $E[X]=1/p=2$, $\mathrm&#123;Var&#125;(X)=(1-p)/p^2=2$. Trap: (A) 1/8 = $P(X=3)$ exactly — $P(\ge k)$ vs $P(=k)$ confusion.
      </div>
    </div>
  </div>

  <!-- Q10 -->
  <div class="q-card" id="qc10">
    <div class="q-header">
      <span class="q-num">Q10</span>
      <span class="q-type q-type--nat">NAT</span>
      <span class="q-diff">★★★</span>
      <span class="q-marks">2 marks · no negative</span>
    </div>
    <div class="q-body">$N_1 \sim \text&#123;Poisson&#125;(2)$ and $N_2 \sim \text&#123;Poisson&#125;(3)$ are independent. The probability that $N_1 + N_2 = 1$ is ___ (two decimals). Use $e^&#123;-5&#125; \approx 0.0067$.</div>
    <div class="q-nat">
      <input type="number" class="q-nat__input" id="q10-input" step="0.01" placeholder="0.00">
      <span class="q-nat__label">two decimal places</span>
    </div>
    <div class="q-footer">
      <button class="q-check-btn" onclick="checkNat(10,0.02,0.04)">Check</button>
      <div class="q-answer" id="q10-ans">
        <b><span class="ans-correct">✓ 0.03.</span></b>
        Poisson additivity: $N_1+N_2 \sim \text&#123;Poisson&#125;(5)$. $P(=1) = e^&#123;-5&#125;\cdot 5/1! = 5e^&#123;-5&#125; \approx 5 \times 0.0067 = 0.0337 \approx 0.03$.
      </div>
    </div>
  </div>

</div><!-- end q-list -->

<div class="gd-gate-box" style="margin-top:24px;">
  <div class="gd-gate-box__title">Score interpretation</div>
  <p><strong>9–10 correct:</strong> discrete distributions solid — advance to <a href="/module1/1-5-questions.html">1.5 Continuous Distributions</a>.</p>
  <p><strong>6–8:</strong> Re-memorise the reference table (mean/variance for each distribution); redo Q3, Q6, Q10.</p>
  <p><strong>&le;5:</strong> Re-read theory and drill the identification step (which distribution applies?) — that's the first thing to determine.</p>
</div>

<a class="gd-pill-link" href="/module1/1-4-bank.html" style="margin-top:8px;">Question Bank (20 Qs) →</a>
<a class="gd-pill-link" href="/module1/index.html" style="margin-top:8px;">Module 1 Overview →</a>

<script is:inline slot="scripts">
var scores={};
function updateScore(){document.getElementById('score-num').textContent=Object.values(scores).filter(Boolean).length;}
function selectOpt(el){var q=el.dataset.q;var card=document.getElementById('qc'+q);if(card.classList.contains('q-card--correct')||card.classList.contains('q-card--wrong'))return;document.querySelectorAll('[data-q="'+q+'"].q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected');});el.classList.add('q-opt--selected');}
function check(q,type,correct){var card=document.getElementById('qc'+q);var selected=document.querySelector('[data-q="'+q+'"].q-opt--selected');var ansEl=document.getElementById('q'+q+'-ans');var btn=card.querySelector('.q-check-btn');if(!selected)return;var val=selected.dataset.val;var isCorrect=val===correct;document.querySelectorAll('[data-q="'+q+'"].q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected');if(o.dataset.val===correct)o.classList.add('q-opt--correct');else if(o.dataset.val===val&&!isCorrect)o.classList.add('q-opt--wrong');o.style.pointerEvents='none';});card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');ansEl.style.display='block';btn.disabled=true;scores[q]=isCorrect;updateScore();}
function checkNat(q,min,max){var input=document.getElementById('q'+q+'-input');var ansEl=document.getElementById('q'+q+'-ans');var card=document.getElementById('qc'+q);var btn=card.querySelector('.q-check-btn');var val=parseFloat(input.value);var isCorrect=!isNaN(val)&&val>=min&&val<=max;input.classList.add(isCorrect?'q-nat__input--correct':'q-nat__input--wrong');input.disabled=true;ansEl.style.display='block';btn.disabled=true;card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');scores[q]=isCorrect;updateScore();}
function checkMsq(q,correctArr){var card=document.getElementById('qc'+q);var ansEl=document.getElementById('q'+q+'-ans');var btn=card.querySelector('.q-check-btn');var checked=Array.from(document.querySelectorAll('[data-q="'+q+'"]:checked')).map(function(c){return c.dataset.val;});var isCorrect=correctArr.length===checked.length&&correctArr.every(function(v){return checked.includes(v);});card.querySelectorAll('.q-opt--msq').forEach(function(label){var val=label.querySelector('input').dataset.val;if(correctArr.includes(val))label.classList.add('q-opt--correct');else if(checked.includes(val))label.classList.add('q-opt--wrong');label.querySelector('input').disabled=true;label.style.pointerEvents='none';});card.classList.add(isCorrect?'q-card--correct':'q-card--wrong');ansEl.style.display='block';btn.disabled=true;scores[q]=isCorrect;updateScore();}
function resetAll(){scores={};updateScore();document.querySelectorAll('.q-card').forEach(function(c){c.classList.remove('q-card--correct','q-card--wrong');});document.querySelectorAll('.q-opt:not(.q-opt--msq)').forEach(function(o){o.classList.remove('q-opt--selected','q-opt--correct','q-opt--wrong');o.style.pointerEvents='';});document.querySelectorAll('.q-nat__input').forEach(function(i){i.value='';i.disabled=false;i.classList.remove('q-nat__input--correct','q-nat__input--wrong');});document.querySelectorAll('.q-opt--msq input').forEach(function(c){c.checked=false;c.disabled=false;});document.querySelectorAll('.q-opt--msq').forEach(function(l){l.classList.remove('q-opt--correct','q-opt--wrong');l.style.pointerEvents='';});document.querySelectorAll('.q-answer').forEach(function(a){a.style.display='none';});document.querySelectorAll('.q-check-btn').forEach(function(b){b.disabled=false;});}
</script>
</VizLayout>
