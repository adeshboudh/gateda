  </a>
</div>

<script is:inline slot="scripts">
// Shared distribution state
const OUTCOMES = [1,2,3,4,5,6];
let rawWeights = [3,5,4,6,5,3];  // unnormalised

function getProbs() {
  const s = d3.sum(rawWeights);
  return rawWeights.map(w => w / s);
}
function getStats() {
  const ps = getProbs();
  const mu  = d3.sum(OUTCOMES, (x,i) => x * ps[i]);
  const ex2 = d3.sum(OUTCOMES, (x,i) => x*x * ps[i]);
  const vr  = ex2 - mu*mu;
  return { mu, vr, sd: Math.sqrt(vr), ps };
}

// ── VIZ 2 params declared first (used inside VIZ 1's draw → drawTransform call)
let aParam = 2, bParam = 3;

// ── VIZ 1: DRAGGABLE PMF ─────────────────
(function() {
  let g, xScale, yScale, W, H;

  function initChart() {
    const container = document.getElementById('pmf-chart');
    const cW = container.clientWidth || 560;
    const cH = Math.round(cW * 0.52);
    const M = { top: 20, right: 20, bottom: 50, left: 50 };
    W = cW - M.left - M.right;
    H = cH - M.top  - M.bottom;

    d3.select(container).select('svg').remove();
    const svg = d3.select(container).append('svg')
      .attr('viewBox', `0 0 ${cW} ${cH}`).style('width','100%').style('height','auto');
    g = svg.append('g').attr('transform', `translate(${M.left},${M.top})`);

    xScale = d3.scaleBand().domain(OUTCOMES).range([0, W]).padding(0.25);
    yScale = d3.scaleLinear().range([H, 0]);

    // Static structure — created once
    g.append('g').attr('class', 'pmf-grid');
    g.append('g').attr('class', 'pmf-bars');
    g.append('g').attr('class', 'pmf-labels');
    g.append('line').attr('class', 'pmf-mean-line');
    g.append('polygon').attr('class', 'pmf-mean-tri');
    g.append('text').attr('class', 'pmf-mean-lbl');
    g.append('line').attr('class', 'pmf-sd-span');
    g.append('g').attr('class', 'axis pmf-x-axis').attr('transform', `translate(0,${H})`);
    g.append('g').attr('class', 'axis pmf-y-axis');

    update();
  }

  function update() {
    const ps = getProbs();
    const st = getStats();
    yScale.domain([0, Math.max(...ps) * 1.3]);

    // Grid
    g.select('.pmf-grid')
      .call(d3.axisLeft(yScale).ticks(4).tickSize(-W).tickFormat(''))
      .call(gr => gr.select('.domain').remove());

    // Bars — D3 join; drag handler stays on persistent elements
    g.select('.pmf-bars').selectAll('rect')
      .data(OUTCOMES)
      .join('rect')
      .attr('x', d => xScale(d))
      .attr('y', (d, i) => yScale(ps[i]))
      .attr('width', xScale.bandwidth())
      .attr('height', (d, i) => Math.max(0, H - yScale(ps[i])))
      .attr('rx', 3).attr('fill', '#7c9eff').attr('opacity', 0.75)
      .style('cursor', 'ns-resize')
      .call(d3.drag()
        .on('drag', function(event, d) {
          const i = OUTCOMES.indexOf(d);
          // event.y is in the g coordinate system (already offset by M.top)
          rawWeights[i] = Math.max(0.1, Math.max(0, H - event.y) / H * 10);
          update();
        })
      );

    // Prob labels
    g.select('.pmf-labels').selectAll('text')
      .data(OUTCOMES)
      .join('text')
      .attr('x', d => xScale(d) + xScale.bandwidth() / 2)
      .attr('y', (d, i) => ps[i] > 0.03 ? yScale(ps[i]) - 4 : -999)
      .attr('text-anchor', 'middle').attr('fill', '#9aa5be').attr('font-size', 10)
      .text((d, i) => ps[i].toFixed(3));

    // Mean line + triangle + label
    const muX = (st.mu - OUTCOMES[0]) / (OUTCOMES[OUTCOMES.length-1] - OUTCOMES[0]) * W;
    g.select('.pmf-mean-line')
      .attr('x1', muX).attr('x2', muX).attr('y1', 0).attr('y2', H)
      .attr('stroke', '#f0a44a').attr('stroke-width', 2).attr('stroke-dasharray', '4 3');
    g.select('.pmf-mean-tri')
      .attr('points', `${muX-7},${H+8} ${muX+7},${H+8} ${muX},${H+1}`)
      .attr('fill', '#f0a44a');
    g.select('.pmf-mean-lbl')
      .attr('x', muX).attr('y', H + 22)
      .attr('text-anchor', 'middle').attr('fill', '#f0a44a')
      .attr('font-size', 11).attr('font-weight', '600')
      .text(`μ=${st.mu.toFixed(2)}`);

    // ±σ span bar
    const spanW = (st.sd / (OUTCOMES[OUTCOMES.length-1] - OUTCOMES[0])) * W;
    g.select('.pmf-sd-span')
      .attr('x1', muX - spanW).attr('x2', muX + spanW)
      .attr('y1', H / 2).attr('y2', H / 2)
      .attr('stroke', 'rgba(240,164,74,0.4)').attr('stroke-width', 6).attr('stroke-linecap', 'round');

    // Axes
    g.select('.pmf-x-axis').call(d3.axisBottom(xScale).tickFormat(d => `X=${d}`));
    g.select('.pmf-y-axis').call(d3.axisLeft(yScale).ticks(4).tickFormat(d3.format('.2f')));

    // Stats panel
    document.getElementById('ex-val').textContent  = st.mu.toFixed(3);
    document.getElementById('var-val').textContent = st.vr.toFixed(3);
    document.getElementById('sd-val').textContent  = st.sd.toFixed(3);
    document.getElementById('exp-live').innerHTML  =
      `E[X] = <span class="live-val">${st.mu.toFixed(3)}</span><br>` +
      `E[X²] = <span class="live-val">${(st.vr + st.mu*st.mu).toFixed(3)}</span><br>` +
      `Var = E[X²]−μ² = <span class="live-val">${st.vr.toFixed(3)}</span>`;
    drawTransform();
  }

  window.redrawPMF = update;
  initChart();
  window.addEventListener('resize', () => setTimeout(initChart, 150));
})();

// ── VIZ 2: LINEAR TRANSFORM ──────────────
function drawTransform() {
  const container = document.getElementById('transform-chart');
  const cW = container.clientWidth || 560;
  const cH = Math.round(cW * 0.45);
  const M = { top: 20, right: 20, bottom: 46, left: 50 };
  const W = cW - M.left - M.right;
  const H = cH - M.top  - M.bottom;

  d3.select(container).select('svg').remove();
  const svg = d3.select(container).append('svg')
    .attr('viewBox',`0 0 ${cW} ${cH}`).style('width','100%').style('height','auto');
  const g = svg.append('g').attr('transform',`translate(${M.left},${M.top})`);

  const ps  = getProbs();
  const st  = getStats();
  const a   = aParam, b = bParam;

  // Transformed outcomes
  const transOut = OUTCOMES.map(xi => a*xi + b);
  const allX = [...OUTCOMES, ...transOut];
  const xMin = Math.min(...allX) - 1, xMax = Math.max(...allX) + 1;

  const x = d3.scaleLinear().domain([xMin, xMax]).range([0, W]);
  const yMax = Math.max(...ps) * 1.3;
  const y = d3.scaleLinear().domain([0, yMax]).range([H, 0]);
  const bw = Math.max(4, W / (xMax - xMin) * 0.4);

  // Grid
  g.append('g').attr('class','grid')
    .call(d3.axisLeft(y).ticks(4).tickSize(-W).tickFormat(''))
    .call(gr => gr.select('.domain').remove());

  // Original bars (blue)
  OUTCOMES.forEach((xi,i) => {
    g.append('rect').attr('x', x(xi) - bw/2).attr('y', y(ps[i]))
      .attr('width', bw).attr('height', Math.max(0,H-y(ps[i])))
      .attr('fill','#7c9eff').attr('opacity',0.7).attr('rx',2);
  });

  // Transformed bars (orange)
  transOut.forEach((xi,i) => {
    g.append('rect').attr('x', x(xi) - bw/2).attr('y', y(ps[i]))
      .attr('width', bw).attr('height', Math.max(0,H-y(ps[i])))
      .attr('fill','#f0a44a').attr('opacity',0.7).attr('rx',2);
  });

  // Mean lines
  const muTrans = a*st.mu + b;
  [
    [st.mu, '#7c9eff', `μ=${st.mu.toFixed(2)}`],
    [muTrans, '#f0a44a', `aμ+b=${muTrans.toFixed(2)}`]
  ].forEach(([val, col, lbl]) => {
    if (val >= xMin && val <= xMax) {
      g.append('line').attr('x1',x(val)).attr('x2',x(val)).attr('y1',0).attr('y2',H)
        .attr('stroke',col).attr('stroke-width',1.5).attr('stroke-dasharray','4 3');
      g.append('text').attr('x',x(val)+4).attr('y',14)
        .attr('fill',col).attr('font-size',10).text(lbl);
    }
  });

  // Legend
  g.append('rect').attr('x',W-90).attr('y',4).attr('width',10).attr('height',10).attr('fill','#7c9eff').attr('rx',2);
  g.append('text').attr('x',W-77).attr('y',13).attr('fill','#9aa5be').attr('font-size',10).text('Original X');
  g.append('rect').attr('x',W-90).attr('y',20).attr('width',10).attr('height',10).attr('fill','#f0a44a').attr('rx',2);
  g.append('text').attr('x',W-77).attr('y',29).attr('fill','#9aa5be').attr('font-size',10).text('aX + b');

  g.append('g').attr('class','axis').attr('transform',`translate(0,${H})`).call(d3.axisBottom(x).ticks(8));
  g.append('g').attr('class','axis').call(d3.axisLeft(y).ticks(4).tickFormat(d3.format('.2f')));

  // Insight
  const varTrans = a*a*st.vr;
  document.getElementById('transform-live').innerHTML =
    `E[aX+b] = ${a.toFixed(1)}×${st.mu.toFixed(2)}+${b.toFixed(1)} = <span class="live-val">${muTrans.toFixed(2)}</span><br>` +
    `Var(aX+b) = ${a.toFixed(1)}²×${st.vr.toFixed(2)} = <span class="live-val">${varTrans.toFixed(2)}</span>`;
  document.getElementById('ins-transform').textContent =
    `Shift b=${b.toFixed(1)} moved mean by ${b.toFixed(1)} but did NOT change variance.`;
  document.getElementById('ins-var-warn').textContent =
    `Scale a=${a.toFixed(1)}: Var multiplied by ${(a*a).toFixed(2)} (a²), not ${Math.abs(a).toFixed(1)} (|a|). σ multiplied by |a|=${Math.abs(a).toFixed(1)}.`;
}

[['a-slider','a-val', v => aParam=v, v=>v.toFixed(1)],
 ['b-slider','b-val', v => bParam=v, v=>v.toFixed(1)]
].forEach(([id,vid,set,fmt]) => {
  document.getElementById(id).addEventListener('input', function() {
    set(+this.value); document.getElementById(vid).textContent = fmt(+this.value); drawTransform();
  });
});
</script>
</VizLayout>
