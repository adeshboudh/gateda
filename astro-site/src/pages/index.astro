---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="GATE DA — Interactive Study Notes" currentPath={Astro.url.pathname}>
  <Fragment slot="head">
    <style is:global>
      .home-hero { padding:60px 0 40px; border-bottom:1px solid var(--gd-border); margin-bottom:40px; }
      .home-hero h1 { font-family:var(--gd-font-head); font-size:2.4rem; font-weight:700; letter-spacing:-0.025em; margin-bottom:12px; }
      .home-hero p { color:var(--gd-text-1); font-size:1rem; max-width:500px; }
      .home-hero .tag { display:inline-block; padding:3px 10px; background:rgba(124,158,255,0.12); color:var(--gd-brand); border-radius:20px; font-size:0.75rem; font-weight:600; margin-bottom:16px; }
      .module-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px; margin-bottom:40px; }
      .module-card { background:var(--gd-bg-2); border:1px solid var(--gd-border); border-radius:var(--gd-r-lg); padding:22px 24px; text-decoration:none; transition:border-color 0.15s,background 0.15s; display:flex; flex-direction:column; gap:10px; }
      .module-card:hover { border-color:var(--gd-brand); background:var(--gd-bg-3); }
      .module-card__num { font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--gd-text-2); }
      .module-card__title { font-family:var(--gd-font-head); font-size:1rem; font-weight:600; color:var(--gd-text-0); }
      .module-card__desc { font-size:0.82rem; color:var(--gd-text-2); line-height:1.5; }
      .module-card__weight { font-size:0.75rem; color:var(--gd-brand); font-weight:600; }
.section-title { font-family:var(--gd-font-head); font-size:1.1rem; font-weight:600; color:var(--gd-text-1); margin-bottom:16px; display:flex; align-items:center; gap:10px; }
      .section-title::after { content:''; flex:1; height:1px; background:var(--gd-border); }
    </style>
  </Fragment>

  <div class="home-hero" style="margin-right:0; max-width:900px;">
    <span class="tag">GATE DA</span>
    <h1>Interactive Study Notes</h1>
    <p>Visual concept explainers + complete text notes with worked examples and practice questions. Built for deep understanding, not just memorisation.</p>
  </div>

  <div style="max-width:900px;">
    <div class="section-title">Modules</div>
    <div class="module-grid">
      <a class="module-card" href="/module1/index.html">
        <div class="module-card__num">Module 1</div>
        <div class="module-card__title">Probability &amp; Statistics</div>
        <div class="module-card__desc">Distributions, Bayes, CLT, hypothesis testing, covariance.</div>
        <div class="module-card__weight">~18% · Highest weight</div>
      </a>
      <div class="module-card" style="opacity:0.5;cursor:default;">
        <div class="module-card__num">Module 2</div>
        <div class="module-card__title">Programming &amp; DSA</div>
        <div class="module-card__desc">Sorting animations, BFS/DFS traversal, binary search, recursion.</div>
        <div class="module-card__weight">~14% · Coming soon</div>
      </div>
      <div class="module-card" style="opacity:0.5;cursor:default;">
        <div class="module-card__num">Module 3</div>
        <div class="module-card__title">Machine Learning</div>
        <div class="module-card__desc">SVM margin, entropy slider, PCA variance, gradient descent.</div>
        <div class="module-card__weight">~17% · Coming soon</div>
      </div>
      <div class="module-card" style="opacity:0.5;cursor:default;">
        <div class="module-card__num">Module 4</div>
        <div class="module-card__title">Databases &amp; Warehousing</div>
        <div class="module-card__desc">B+ tree insertion, SQL join, OLAP cuboid drill-down.</div>
        <div class="module-card__weight">~14% · Coming soon</div>
      </div>
      <div class="module-card" style="opacity:0.5;cursor:default;">
        <div class="module-card__num">Module 5</div>
        <div class="module-card__title">Linear Algebra</div>
        <div class="module-card__desc">Eigenvector transformation, SVD, matrix multiply visualization.</div>
        <div class="module-card__weight">~12% · Coming soon</div>
      </div>
      <div class="module-card" style="opacity:0.5;cursor:default;">
        <div class="module-card__num">Module 6</div>
        <div class="module-card__title">Artificial Intelligence</div>
        <div class="module-card__desc">A* search on a grid, minimax game tree, Bayes net DAG.</div>
        <div class="module-card__weight">~9% · Coming soon</div>
      </div>
      <div class="module-card" style="opacity:0.5;cursor:default;">
        <div class="module-card__num">Module 7</div>
        <div class="module-card__title">Calculus &amp; Optimization</div>
        <div class="module-card__desc">Taylor series approx, gradient descent on a loss surface.</div>
        <div class="module-card__weight">~8% · Coming soon</div>
      </div>
    </div>
  </div>
</BaseLayout>
